# PulseReport environment variables
# Copy this file to .env.local and fill in your keys.

# --- Gemini (Google Generative AI) ---
# Get a key at https://aistudio.google.com/app/apikey
# Without this key the app falls back to a built-in demo report so the
# UI/demo never breaks.
GEMINI_API_KEY=

# Optional model override (defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# --- Novus.ai / Pendo analytics ---
# (1) BROWSER TRACKING (mandatory): the agent/app API key used in the snippet
#     URL cdn.pendo.io/agent/static/<APP_KEY>/pendo.js. Novus.ai → Install.
#     When empty, analytics calls are safe no-ops.
NEXT_PUBLIC_NOVUS_API_KEY=

# (2) SERVER-SIDE PENDO API (optional): OAuth client credentials for pulling
#     aggregate usage data. NOT used by the browser snippet. Server-only.
NOVUS_CLIENT_ID=
NOVUS_CLIENT_SECRET=
